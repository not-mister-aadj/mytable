# MapKit (optional)
MAPKIT_TEAM_ID=
MAPKIT_KEY_ID=
MAPKIT_PRIVATE_KEY=

# === Localhost: MyTable-dev (Supabase dev project) ===
# Paste from Supabase → MyTable-dev → Project Settings
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Production DB source for db:sync-dev — copy .env.production.local.example
# DEV_SYNC_ON_START=false skips prod→dev sync on npm run dev

# Stripe (STOP 3 test, STOP 4 live)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3001
# Production only — use dashboard subdomain on Vercel, not for local npm run dev
# NEXT_PUBLIC_SITE_URL=https://mytable.club
NEXT_PUBLIC_ADMIN_URL=https://dashboard.mytable.club
# Optional: force local OAuth origin if you keep production URLs above during dev
LOCAL_DEV_ORIGIN=http://localhost:3001
ADMIN_HOST=dashboard.mytable.club
USE_DB_EVENTS=true
NEXT_PUBLIC_USE_DB_EVENTS=true
ADMIN_EMAILS=you@example.com
MAX_SEATS_PER_ORDER=4
SHOW_VIEW_COUNT=false

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=MyTable <info@mytable.club>
EMAIL_REPLY_TO=info@mytable.club
